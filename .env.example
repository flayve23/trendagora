# ─── Supabase ────────────────────────────────────────────────
# Pegue em: https://supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ─── Auth Admin ──────────────────────────────────────────────
# Defina um segredo forte qualquer (ex: openssl rand -base64 32)
ADMIN_SECRET=troque_por_segredo_forte_aqui

# ─── Google Analytics ────────────────────────────────────────
# Opcional: cole seu Measurement ID do GA4 (ex: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# ─── OpenAI (geração de conteúdo com IA) ─────────────────────
# Opcional: cole sua API key da OpenAI para ativar geração real
OPENAI_API_KEY=
